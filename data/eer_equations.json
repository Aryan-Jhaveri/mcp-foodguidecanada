{
  "_metadata": {
    "source": "Health Canada DRI Tables",
    "url": "https://www.canada.ca/en/health-canada/services/food-nutrition/healthy-eating/dietary-reference-intakes/tables/equations-estimate-energy-requirement.html",
    "snapshot_date": "2026-03-02",
    "last_verified": "2026-03-02",
    "notes": "Bundled static snapshot. EER equations from Health Canada DRI tables. Variables: age (years), height (cm), weight (kg), gestation (weeks)."
  },
  "general_note": "These equations provide an estimate of energy requirement (EER). Relative body weight (that is, loss, stable, gain) is the preferred indicator of energy adequacy.",
  "pal_category_definitions": {
    "description": "Physical Activity Level (PAL) category ranges by age group",
    "age_groups": {
      "3_to_9_years": {
        "inactive": {"min": 1.00, "max": 1.31},
        "low_active": {"min": 1.31, "max": 1.44},
        "active": {"min": 1.44, "max": 1.59},
        "very_active": {"min": 1.59, "max": 2.50}
      },
      "9_to_14_years": {
        "inactive": {"min": 1.00, "max": 1.44},
        "low_active": {"min": 1.44, "max": 1.59},
        "active": {"min": 1.59, "max": 1.77},
        "very_active": {"min": 1.77, "max": 2.50}
      },
      "14_to_19_years": {
        "inactive": {"min": 1.00, "max": 1.56},
        "low_active": {"min": 1.56, "max": 1.73},
        "active": {"min": 1.73, "max": 1.92},
        "very_active": {"min": 1.92, "max": 2.50}
      },
      "19_years_and_older": {
        "inactive": {"min": 1.00, "max": 1.53},
        "low_active": {"min": 1.53, "max": 1.68},
        "active": {"min": 1.68, "max": 1.85},
        "very_active": {"min": 1.85, "max": 2.50}
      }
    },
    "adult_activity_examples": {
      "inactive": "30 min walking + 90 min light to moderate activity",
      "low_active": "60 to 80 min of walking at 5-7 km/h",
      "active": "30-50 min walking + 45 min moderate cycling + 40 min doubles tennis",
      "very_active": "45 min moderate cycling + 25 min jogging at 10 km/h + 60 min doubles tennis"
    }
  },
  "pal_descriptions": {
    "inactive": {
      "description": "Sedentary lifestyle",
      "examples": [
        "Typical daily living activities only",
        "Sitting most of the day",
        "Little to no structured exercise"
      ]
    },
    "low_active": {
      "description": "Low active lifestyle",
      "examples": [
        "Daily living activities plus 30-60 minutes of moderate activity",
        "Walking 2.5-5 km per day",
        "Light exercise 3-4 times per week"
      ]
    },
    "active": {
      "description": "Active lifestyle",
      "examples": [
        "Daily living activities plus 60+ minutes of moderate activity",
        "Walking 7.5-10 km per day",
        "Regular structured exercise 4-5 times per week"
      ]
    },
    "very_active": {
      "description": "Very active lifestyle",
      "examples": [
        "Daily living activities plus 60+ minutes of moderate to vigorous activity",
        "Walking 12.5+ km per day",
        "Intensive training or physical work"
      ]
    }
  },
  "equations": {
    "infant_toddler": {
      "description": "Infants and toddlers 0-3 years. No activity level differentiation.",
      "age_range": "0 to <3 years",
      "male": {
        "formula": "EER = -716.45 - (1.00 * age) + (17.82 * height_cm) + (15.06 * weight_kg) + growth_constant",
        "coefficients": {
          "intercept": -716.45,
          "age": -1.00,
          "height_cm": 17.82,
          "weight_kg": 15.06
        },
        "growth_constants": {
          "0_to_3_months": 200,
          "3_to_6_months": 50,
          "6_to_12_months": 20,
          "1_to_3_years": 20
        }
      },
      "female": {
        "formula": "EER = -69.15 + (80.0 * age) + (2.65 * height_cm) + (54.15 * weight_kg) + growth_constant",
        "coefficients": {
          "intercept": -69.15,
          "age": 80.0,
          "height_cm": 2.65,
          "weight_kg": 54.15
        },
        "growth_constants": {
          "0_to_3_months": 180,
          "3_to_6_months": 60,
          "6_to_12_months": 20,
          "1_to_3_years": 15
        }
      }
    },
    "child_adolescent": {
      "description": "Children and adolescents 3-18 years. Activity level dependent with age-specific growth constants.",
      "age_range": "3 to <19 years",
      "male": {
        "inactive": {
          "formula": "EER = -447.51 + (3.68 * age) + (13.01 * height_cm) + (13.15 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -447.51, "age": 3.68, "height_cm": 13.01, "weight_kg": 13.15}
        },
        "low_active": {
          "formula": "EER = 19.12 + (3.68 * age) + (8.62 * height_cm) + (20.28 * weight_kg) + growth_constant",
          "coefficients": {"intercept": 19.12, "age": 3.68, "height_cm": 8.62, "weight_kg": 20.28}
        },
        "active": {
          "formula": "EER = -388.19 + (3.68 * age) + (12.66 * height_cm) + (20.46 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -388.19, "age": 3.68, "height_cm": 12.66, "weight_kg": 20.46}
        },
        "very_active": {
          "formula": "EER = -671.75 + (3.68 * age) + (15.38 * height_cm) + (23.25 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -671.75, "age": 3.68, "height_cm": 15.38, "weight_kg": 23.25}
        },
        "growth_constants": {
          "3_to_4_years": 20,
          "4_to_9_years": 15,
          "9_to_14_years": 25,
          "14_to_19_years": 20
        }
      },
      "female": {
        "inactive": {
          "formula": "EER = 55.59 + (-22.25 * age) + (8.43 * height_cm) + (17.07 * weight_kg) + growth_constant",
          "coefficients": {"intercept": 55.59, "age": -22.25, "height_cm": 8.43, "weight_kg": 17.07}
        },
        "low_active": {
          "formula": "EER = -297.54 + (-22.25 * age) + (12.77 * height_cm) + (14.73 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -297.54, "age": -22.25, "height_cm": 12.77, "weight_kg": 14.73}
        },
        "active": {
          "formula": "EER = -189.55 + (-22.25 * age) + (11.74 * height_cm) + (18.34 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -189.55, "age": -22.25, "height_cm": 11.74, "weight_kg": 18.34}
        },
        "very_active": {
          "formula": "EER = -709.59 + (-22.25 * age) + (18.22 * height_cm) + (14.25 * weight_kg) + growth_constant",
          "coefficients": {"intercept": -709.59, "age": -22.25, "height_cm": 18.22, "weight_kg": 14.25}
        },
        "growth_constants": {
          "3_to_4_years": 15,
          "4_to_9_years": 15,
          "9_to_14_years": 30,
          "14_to_19_years": 20
        }
      }
    },
    "adult": {
      "description": "Adults 19 years and older. No growth constant.",
      "age_range": "19+ years",
      "male": {
        "inactive": {
          "formula": "EER = 753.07 + (-10.83 * age) + (6.50 * height_cm) + (14.10 * weight_kg)",
          "coefficients": {"intercept": 753.07, "age": -10.83, "height_cm": 6.50, "weight_kg": 14.10}
        },
        "low_active": {
