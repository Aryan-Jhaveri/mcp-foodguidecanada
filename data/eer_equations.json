          "coefficients": {"intercept": 581.47, "age": -10.83, "height_cm": 8.30, "weight_kg": 14.94}
        },
        "active": {
          "formula": "EER = 1004.82 + (-10.83 * age) + (6.52 * height_cm) + (15.91 * weight_kg)",
          "coefficients": {"intercept": 1004.82, "age": -10.83, "height_cm": 6.52, "weight_kg": 15.91}
        },
        "very_active": {
          "formula": "EER = -517.88 + (-10.83 * age) + (15.61 * height_cm) + (19.11 * weight_kg)",
          "coefficients": {"intercept": -517.88, "age": -10.83, "height_cm": 15.61, "weight_kg": 19.11}
        }
      },
      "female": {
        "inactive": {
          "formula": "EER = 584.90 + (-7.01 * age) + (5.72 * height_cm) + (11.71 * weight_kg)",
          "coefficients": {"intercept": 584.90, "age": -7.01, "height_cm": 5.72, "weight_kg": 11.71}
        },
        "low_active": {
          "formula": "EER = 575.77 + (-7.01 * age) + (6.60 * height_cm) + (12.14 * weight_kg)",
          "coefficients": {"intercept": 575.77, "age": -7.01, "height_cm": 6.60, "weight_kg": 12.14}
        },
        "active": {
          "formula": "EER = 710.25 + (-7.01 * age) + (6.54 * height_cm) + (12.34 * weight_kg)",
          "coefficients": {"intercept": 710.25, "age": -7.01, "height_cm": 6.54, "weight_kg": 12.34}
        },
        "very_active": {
          "formula": "EER = 511.83 + (-7.01 * age) + (9.07 * height_cm) + (12.56 * weight_kg)",
          "coefficients": {"intercept": 511.83, "age": -7.01, "height_cm": 9.07, "weight_kg": 12.56}
        }
      }
    },
    "pregnancy": {
      "description": "Pregnancy equations for 2nd and 3rd trimester. For 1st trimester, use non-pregnant female equations.",
      "age_range": "All ages",
      "note": "Use non-pregnant female equations for first trimester",
      "equations_by_pal": {
        "inactive": {
          "formula": "EER = 1131.20 + (-2.04 * age) + (0.34 * height_cm) + (12.15 * weight_kg) + (9.16 * gestation_weeks) + energy_deposition",
          "coefficients": {"intercept": 1131.20, "age": -2.04, "height_cm": 0.34, "weight_kg": 12.15, "gestation_weeks": 9.16}
        },
        "low_active": {
          "formula": "EER = 693.35 + (-2.04 * age) + (5.73 * height_cm) + (10.20 * weight_kg) + (9.16 * gestation_weeks) + energy_deposition",
          "coefficients": {"intercept": 693.35, "age": -2.04, "height_cm": 5.73, "weight_kg": 10.20, "gestation_weeks": 9.16}
        },
        "active": {
          "formula": "EER = -223.84 + (-2.04 * age) + (13.23 * height_cm) + (8.15 * weight_kg) + (9.16 * gestation_weeks) + energy_deposition",
          "coefficients": {"intercept": -223.84, "age": -2.04, "height_cm": 13.23, "weight_kg": 8.15, "gestation_weeks": 9.16}
        },
        "very_active": {
          "formula": "EER = -779.72 + (-2.04 * age) + (18.45 * height_cm) + (8.73 * weight_kg) + (9.16 * gestation_weeks) + energy_deposition",
          "coefficients": {"intercept": -779.72, "age": -2.04, "height_cm": 18.45, "weight_kg": 8.73, "gestation_weeks": 9.16}
        }
      },
      "energy_deposition_by_bmi": {
        "underweight": {"bmi_range": "< 18.5", "kcal_per_day": 300},
        "normal_weight": {"bmi_range": "18.5 - 24.9", "kcal_per_day": 200},
        "overweight": {"bmi_range": "25.0 - 29.9", "kcal_per_day": 150},
        "obese": {"bmi_range": ">= 30.0", "kcal_per_day": -50}
      }
    },
    "lactation": {
      "description": "Breastfeeding equations. Uses non-pregnant female base equations plus milk energy constants.",
      "age_range": "All ages",
      "note": "Base equation uses adolescent female coefficients for age <19, adult female coefficients for age 19+",
      "milk_energy_constants": {
        "0_to_6_months_postpartum": {
          "total_addition_kcal": 400,
          "breakdown": "540 (milk energy output) - 140 (weight loss allowance)"
        },
        "7_to_12_months_postpartum": {
          "total_addition_kcal": 380,
          "breakdown": "380 (milk energy output, no weight loss allowance)"
        }
      },
      "base_equations": {
        "age_under_19": {
          "description": "Uses adolescent female (3-18y) coefficients",
          "inactive": {"coefficients": {"intercept": 55.59, "age": -22.25, "height_cm": 8.43, "weight_kg": 17.07}},
          "low_active": {"coefficients": {"intercept": -297.54, "age": -22.25, "height_cm": 12.77, "weight_kg": 14.73}},
          "active": {"coefficients": {"intercept": -189.55, "age": -22.25, "height_cm": 11.74, "weight_kg": 18.34}},
